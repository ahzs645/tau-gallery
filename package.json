{
  "name": "tau-gallery",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm build",
    "projects:sync": "node scripts/sync-playground-projects.mjs",
    "projects:check": "node scripts/check-project-assets.mjs",
    "version:write": "node scripts/write-version.mjs",
    "tau:check": "node scripts/check-tau-packages.mjs",
    "tau:update": "pnpm up @taucad/runtime@beta @taucad/types@beta && pnpm verify"
  },
  "dependencies": {
    "@taucad/openscad": "0.1.0-beta.0",
    "@taucad/runtime": "0.1.0-beta.0",
    "@taucad/types": "0.1.0-beta.0",
    "buffer": "6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
